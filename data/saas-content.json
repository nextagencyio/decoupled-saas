        "eyebrow": "About Us",
        "title": "We're building the future of work automation",
        "subtitle": "Founded in 2021, CloudFlow was born from a simple idea: teams shouldn't spend time on repetitive tasks when software can do it better.",
        "layout": "centered",
        "background_color": "light"
      }
