      "values": {
        "eyebrow": "Get Started",
        "title": "Ready to automate your workflows?",
        "subtitle": "Join 10,000+ teams that trust CloudFlow to run their business. Start your free trial today -- no credit card required.",
        "primary_cta_text": "Start Free Trial",
        "primary_cta_url": "/features",
        "secondary_cta_text": "Talk to Sales",
        "secondary_cta_url": "/contact-sales",
        "background_color": "dark"
