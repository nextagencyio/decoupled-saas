    {
      "id": "feature-card-1",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "Workflow",
        "title": "Visual Workflow Builder",
        "description": "Design complex automations with our drag-and-drop builder. No code required. Connect triggers, conditions, and actions in minutes.",
        "link_text": "Learn more",
        "link_url": "/features/workflows"
      }
    },
    {
      "id": "feature-card-2",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "BarChart3",
        "title": "Real-Time Analytics",
        "description": "Track every metric that matters. Custom dashboards, automated reports, and AI-powered insights delivered to your inbox.",
        "link_text": "Learn more",
        "link_url": "/features/analytics"
      }
    },
    {
      "id": "feature-card-3",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "Shield",
        "title": "Enterprise Security",
        "description": "SOC 2 Type II certified. End-to-end encryption, SSO, RBAC, and audit logs. Your data is protected at every layer.",
        "link_text": "Learn more",
        "link_url": "/features/security"
      }
    },
    {
      "id": "feature-card-4",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "Plug",
        "title": "150+ Integrations",
        "description": "Connect CloudFlow with Slack, Salesforce, HubSpot, Stripe, and 150+ other tools your team already uses.",
        "link_text": "View integrations",
        "link_url": "/integrations"
      }
    },
    {
      "id": "feature-card-5",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "Users",
        "title": "Team Collaboration",
        "description": "Shared workspaces, real-time editing, comments, and approvals. Keep everyone aligned and moving fast.",
        "link_text": "Learn more",
        "link_url": "/features/collaboration"
      }
    },
    {
      "id": "feature-card-6",
      "type": "paragraph.feature_card",
      "values": {
        "icon": "Bot",
        "title": "AI Assistant",
        "description": "Let CloudFlow AI suggest optimizations, detect anomalies, and automate repetitive tasks across your workflows.",
        "link_text": "Learn more",
        "link_url": "/features/ai"
      }
    },
    {
      "id": "features-section",
      "type": "paragraph.feature_grid",
      "values": {
        "eyebrow": "Features",
        "title": "Everything you need to scale operations",
        "subtitle": "A unified platform that replaces a dozen tools. Built for teams that demand speed, reliability, and flexibility.",
        "columns": "3",
        "cards": ["@feature-card-1", "@feature-card-2", "@feature-card-3", "@feature-card-4", "@feature-card-5", "@feature-card-6"]
      }
    },
    {
      "id": "pricing-free",
      "type": "paragraph.pricing_tier",
      "values": {
        "name": "Free",
        "price": "$0",
        "billing_period": "forever",
        "description": "For individuals and small projects",
        "features": ["Up to 5 workflows", "1,000 tasks/month", "3 integrations", "Community support", "Basic analytics"],
        "is_featured": false,
        "cta_text": "Get Started",
        "cta_url": "/signup?plan=free"
      }
    },
    {
      "id": "pricing-pro",
      "type": "paragraph.pricing_tier",
      "values": {
        "name": "Pro",
        "price": "$49",
        "billing_period": "/month",
        "description": "For growing teams and businesses",
        "features": ["Unlimited workflows", "50,000 tasks/month", "All integrations", "Priority support", "Advanced analytics", "Custom dashboards", "Team workspaces", "API access"],
        "is_featured": true,
        "cta_text": "Start Free Trial",
        "cta_url": "/signup?plan=pro"
      }
    },
    {
      "id": "pricing-enterprise",
      "type": "paragraph.pricing_tier",
      "values": {
        "name": "Enterprise",
        "price": "Custom",
        "billing_period": "",
        "description": "For large organizations with custom needs",
        "features": ["Everything in Pro", "Unlimited tasks", "SSO & SAML", "Dedicated account manager", "Custom SLA", "On-premise deployment", "Advanced security controls", "Custom integrations"],
        "is_featured": false,
        "cta_text": "Contact Sales",
        "cta_url": "/contact-sales"
      }
    },
    {
      "id": "pricing-section",
      "type": "paragraph.pricing_table",
      "values": {
        "eyebrow": "Pricing",
        "title": "Simple, predictable pricing",
        "subtitle": "Start free. Upgrade when you're ready. No surprises on your bill.",
        "tiers": ["@pricing-free", "@pricing-pro", "@pricing-enterprise"]
      }
    },
    {
      "id": "testimonial-1",
      "type": "paragraph.testimonial",
      "values": {
        "quote": "CloudFlow cut our manual processes by 80%. What used to take our ops team a full day now runs automatically before anyone gets to the office.",
        "author_name": "Rachel Torres",
        "author_title": "VP of Operations",
        "author_company": "ScaleUp Inc.",
        "author_image": {
          "url": "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=200&h=200&fit=crop&crop=face&q=80",
          "alt": "Rachel Torres headshot"
        },
        "rating": "5"
      }
    },
    {
      "id": "testimonial-2",
      "type": "paragraph.testimonial",
      "values": {
        "quote": "We replaced four separate tools with CloudFlow. The integrations are seamless and the workflow builder is incredibly intuitive. Our team adopted it in a week.",
        "author_name": "David Kim",
        "author_title": "CTO",
        "author_company": "Meridian Labs",
        "author_image": {
          "url": "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face&q=80",
          "alt": "David Kim headshot"
        },
        "rating": "5"
      }
    },
    {
      "id": "testimonial-3",
      "type": "paragraph.testimonial",
      "values": {
        "quote": "The analytics alone are worth the price. We finally have visibility into our pipeline and can make data-driven decisions in real time.",
        "author_name": "Priya Patel",
        "author_title": "Head of Growth",
        "author_company": "Apex Digital",
        "author_image": {
          "url": "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=200&h=200&fit=crop&crop=face&q=80",
          "alt": "Priya Patel headshot"
        },
        "rating": "5"
      }
    },
    {
      "id": "quotes-section",
      "type": "paragraph.testimonial_slider",
      "values": {
        "eyebrow": "Customer Stories",
        "title": "Trusted by fast-growing teams",
        "layout": "grid",
        "testimonials": ["@testimonial-1", "@testimonial-2", "@testimonial-3"]
      }
    },
    {
      "id": "faq-1",
      "type": "paragraph.faq_item",
      "values": {
        "question": "How quickly can I get started with CloudFlow?",
        "answer": "<p>You can sign up and build your first workflow in under 5 minutes. Our templates library has 200+ pre-built automations for common use cases like lead routing, customer onboarding, and invoice processing.</p>"
      }
    },
    {
      "id": "faq-2",
      "type": "paragraph.faq_item",
      "values": {
        "question": "Can I migrate from my current automation tool?",
        "answer": "<p>Yes. We offer free migration assistance for Pro and Enterprise plans. Our team will help you recreate your workflows in CloudFlow and ensure zero downtime during the transition.</p>"
      }
    },
    {
      "id": "faq-3",
      "type": "paragraph.faq_item",
      "values": {
        "question": "What integrations do you support?",
        "answer": "<p>CloudFlow connects with 150+ tools including Slack, Salesforce, HubSpot, Stripe, Google Workspace, Microsoft 365, Jira, GitHub, and many more. We also offer a REST API and webhooks for custom integrations.</p>"
      }
    },
    {
      "id": "faq-4",
      "type": "paragraph.faq_item",
      "values": {
        "question": "Is my data secure?",
        "answer": "<p>Absolutely. CloudFlow is SOC 2 Type II certified with end-to-end encryption, SSO support, and role-based access controls. We never sell your data and comply with GDPR, CCPA, and HIPAA requirements.</p>"
      }
    },
    {
      "id": "faq-5",
      "type": "paragraph.faq_item",
      "values": {
        "question": "What happens if I exceed my task limit?",
        "answer": "<p>We'll notify you when you reach 80% of your plan limit. You can upgrade anytime, and we never stop your workflows mid-execution. Overages are billed at a reasonable per-task rate.</p>"
      }
    },
    {
      "id": "faq-section",
      "type": "paragraph.accordion",
      "values": {
        "eyebrow": "FAQ",
        "title": "Frequently asked questions",
        "subtitle": "Everything you need to know about CloudFlow. Can't find your answer? Contact our support team.",
        "items": ["@faq-1", "@faq-2", "@faq-3", "@faq-4", "@faq-5"]
      }
    },
