  "content": [
    {
      "id": "hero-main",
      "type": "paragraph.hero_section",
      "values": {
        "eyebrow": "CloudFlow Platform",
        "title": "Automate your workflows. Accelerate your growth.",
        "subtitle": "CloudFlow is the all-in-one SaaS platform that streamlines operations, connects your tools, and gives your team superpowers. Start free today.",
        "layout": "centered",
        "background_color": "gradient",
        "background_image": {
          "url": "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&h=1080&fit=crop&q=80",
          "alt": "Abstract cloud technology background"
        },
        "primary_cta_text": "Start Free Trial",
        "primary_cta_url": "/features",
        "secondary_cta_text": "Watch Demo",
        "secondary_cta_url": "/features"
      }
    },
