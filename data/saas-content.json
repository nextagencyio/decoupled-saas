      "type": "paragraph.text_block",
      "values": {
        "title": "Why CloudFlow?",
        "content": "<p>CloudFlow was built from the ground up to solve the operational challenges that hold teams back. We combine workflow automation, real-time analytics, and seamless integrations into a single platform that your entire organization can rally around.</p><p>Unlike point solutions that only address one problem, CloudFlow connects your entire operational stack -- from lead generation to customer success -- giving you end-to-end visibility and control.</p>",
        "alignment": "left",
        "cta_text": "Start Free Trial",
        "cta_url": "/features"
      }
    },
